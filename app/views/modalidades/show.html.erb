<div class="page">
  <div class="page-header">
    <div>
      <%= link_to "← Modalidades", modalidades_path, class: "back-link" %>
      <h1><%= @modalidade.nome %></h1>
    </div>
    <% if current_user.admin? %>
      <div class="page-header__actions">
        <%= link_to "Editar", edit_modalidade_path(@modalidade), class: "btn btn-primary btn-sm" %>
        <%= button_to "Excluir",
          @modalidade,
          method: :delete,
          class: "btn btn-danger btn-sm",
          data: { turbo_confirm: "Excluir #{@modalidade.nome}?" } %>
      </div>
    <% end %>
  </div>

  <div class="item-card item-card--highlight">
    <p class="item-card__title"><%= @modalidade.nome %></p>
    <div class="item-card__meta">
      <div class="item-card__meta-row">
        <span class="item-card__label">Turmas</span>
        <%= @modalidade.turmas.count %>
      </div>
    </div>
  </div>
</div>
