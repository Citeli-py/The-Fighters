<%= form_with(model: modalidade) do |form| %>

  <% if modalidade.errors.any? %>
    <div class="form-errors">
      <h3><%= pluralize(modalidade.errors.count, "erro") %> encontrado(s):</h3>
      <ul>
        <% modalidade.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= form.label :nome, "Nome da modalidade" %>
    <%= form.text_field :nome, class: "form-input", placeholder: "Ex: Taekwondo, Kickboxing..." %>
  </div>

  <div class="form-actions">
    <%= form.submit modalidade.persisted? ? "Salvar alterações" : "Criar modalidade", class: "btn btn-primary" %>
    <%= link_to "Cancelar", modalidade.persisted? ? modalidade : modalidades_path, class: "btn btn-ghost" %>
  </div>

<% end %>
