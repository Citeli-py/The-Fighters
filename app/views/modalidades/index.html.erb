<div class="page">
  <div class="page-header">
    <div>
      <%= link_to "← Dashboard", root_path, class: "back-link" %>
      <h1>Modalidades <span class="count-badge"><%= @modalidades.count %></span></h1>
    </div>
    <%= link_to "＋ Nova modalidade", new_modalidade_path, class: "btn btn-primary" %>
  </div>

  <% if notice.present? %>
    <div class="alert-success"><%= notice %></div>
  <% end %>

  <% if @modalidades.any? %>
    <div class="grid">
      <% @modalidades.each do |modalidade| %>
        <%= render modalidade %>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      <div class="empty-state__icon">🥋</div>
      <p class="empty-state__text">Nenhuma modalidade cadastrada ainda.</p>
      <%= link_to "Criar primeira modalidade", new_modalidade_path, class: "btn btn-primary" %>
    </div>
  <% end %>
</div>
