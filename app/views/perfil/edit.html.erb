<div class="page">
  <div class="page-header">
    <div>
      <%= link_to "← Dashboard", root_path, class: "back-link" %>
      <h1>Meu perfil</h1>
    </div>
  </div>

  <div class="card">
    <div class="card-header">Alterar senha</div>

    <%= form_with model: current_user, url: perfil_path, method: :patch, class: "form-card" do |f| %>
      <%= render "shared/form_errors", resource: current_user %>

      <div class="form-group">
        <%= f.label :current_password, "Senha atual" %>
        <%= f.password_field :current_password, class: "form-input",
              autocomplete: "current-password" %>
      </div>

      <div class="form-group">
        <%= f.label :password, "Nova senha" %>
        <%= f.password_field :password, class: "form-input",
              autocomplete: "new-password" %>
      </div>

      <div class="form-group">
        <%= f.label :password_confirmation, "Confirmar nova senha" %>
        <%= f.password_field :password_confirmation, class: "form-input",
              autocomplete: "new-password" %>
      </div>

      <div class="form-actions">
        <%= f.submit "Salvar senha", class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>
