<p style="color: green"><%= notice %></p>

<% content_for :title, "Horarios" %>

<div class="page-header">
  <h1>Horarios</h1>

  <%= link_to "➕ Novo horario",
    new_horario_path,
    class: "btn btn-primary"
  %>
</div>

<div id="horarios">
  <% @horarios.each do |horario| %>
    <%= render horario %>
    <p>
      <%= link_to "Show this horario", horario %>
    </p>
  <% end %>
</div>

<%= link_to "New horario", new_horario_path %>
