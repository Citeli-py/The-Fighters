<div class="page">
  <div class="page-header">
    <div>
      <%= link_to "← Dashboard", root_path, class: "back-link" %>
      <h1>Horários <span class="count-badge"><%= @horarios.count %></span></h1>
    </div>
    <%= link_to "＋ Novo horário", new_horario_path, class: "btn btn-primary" %>
  </div>

  <% if notice.present? %>
    <div class="alert-success"><%= notice %></div>
  <% end %>

  <% if @horarios.any? %>
    <div class="grid">
      <% @horarios.each do |horario| %>
        <%= render horario %>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      <div class="empty-state__icon">🕒</div>
      <p class="empty-state__text">Nenhum horário cadastrado ainda.</p>
    </div>
  <% end %>
</div>
