<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "The Fighters" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="The Fighters">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <div id="toast-container" class="toast-container">
      <% if notice.present? %>
        <%= render "shared/toast", type: "success", message: notice %>
      <% end %>
      <% if alert.present? %>
        <%= render "shared/toast", type: "error", message: alert %>
      <% end %>
    </div>

    <div class="auth-layout">
      <aside class="auth-brand">
        <img src="/logo.png" alt="The Fighters" class="auth-brand-logo" />
        <div class="auth-brand-stripe"></div>
        <h1 class="auth-brand-title">The Fighters</h1>
        <p class="auth-brand-subtitle">Escola de Taekwondo</p>
        <span class="auth-brand-since">Desde 2014</span>
      </aside>

      <main class="auth-form-panel">
        <%= yield %>
      </main>
    </div>
  </body>
</html>
