<div id="<%= dom_id presenca %>" class="presenca-chip">
  <span><%= presenca.aluno.nome %></span>
  <%= button_to "✕",
    aula_presenca_path(presenca.aula, presenca),
    method: :delete,
    class: "btn btn-danger btn-sm",
    data: { turbo_confirm: "Remover presença de #{presenca.aluno.nome}?" } %>
</div>
