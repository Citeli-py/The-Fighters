<%= form_with(model: aluno) do |form| %>
  <% if aluno.errors.any? %>
    <div class="form-errors">
      <h3><%= pluralize(aluno.errors.count, "erro") %> encontrado(s):</h3>
      <ul>
        <% aluno.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= form.label :nome, "Nome completo" %>
    <%= form.text_field :nome, class: "form-input", placeholder: "Ex: João da Silva" %>
  </div>

  <div class="form-grid">
    <div class="form-group">
      <%= form.label :data_nascimento, "Data de nascimento" %>
      <%= form.date_field :data_nascimento, class: "form-input" %>
    </div>
    <div class="form-group">
      <%= form.label :cpf, "CPF" %>
      <%= form.text_field :cpf, class: "form-input", placeholder: "000.000.000-00" %>
    </div>
  </div>

  <div class="form-actions">
    <%= form.submit aluno.persisted? ? "Salvar alterações" : "Cadastrar aluno", class: "btn btn-primary" %>
    <%= link_to "Cancelar", aluno.persisted? ? aluno : alunos_path, class: "btn btn-ghost" %>
  </div>
<% end %>
