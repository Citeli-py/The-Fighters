<div class="page">
  <div class="page-header">
    <div>
      <%= link_to "← Aulas", aulas_path, class: "back-link" %>
      <h1>Aula</h1>
    </div>
  </div>

  <div class="aula-hero">
    <div class="aula-hero__info">
      <h2 class="aula-hero__title"><%= @aula.horario.turma.nome %></h2>
      <div class="aula-hero__meta">
        <span><%= @aula.data_hora_formatada %></span>
      </div>
      <span class="status-badge status-badge--<%= @aula.status_nome.downcase %>">
        <%= @aula.status_nome %>
      </span>

      <% if current_user.admin? %>
        <div class="aula-hero__actions">
          <% if @aula.is_cancelada && !@aula.is_realizada %>
            <%= button_to "Confirmar aula",
              confirm_aula_path(@aula),
              method: :patch,
              class: "btn btn-primary btn-sm"
            %>
          <% end %>
          <% unless @aula.is_cancelada %>
            <%= button_to "Cancelar aula",
              cancel_aula_path(@aula),
              method: :patch,
              class: "btn btn-danger btn-sm",
              data: { turbo_confirm: "Cancelar esta aula?" }
            %>
          <% end %>
        </div>
      <% end %>
    </div>

    <% if current_user.admin? %>
      <div class="aula-qr">
        <span class="aula-qr__label">QR Code da Aula</span>
        <%= raw @qr.as_svg(
          offset: 0,
          color: "FFF",
          shape_rendering: "crispEdges",
          module_size: 6,
          standalone: true
        ) %>
      </div>
    <% end %>
  </div>

  <div class="page-section">
    <div class="page-section__header">
      <h2 class="page-section__title">
        Presenças confirmadas
        <span id="presencas-count" class="count-badge"><%= @presencas.count %></span>
      </h2>
    </div>

    <div id="presencas-grid" class="presencas-grid">
      <%= render @presencas %>
    </div>
  </div>

  <% if current_user.admin? %>
    <div class="page-section">
      <div class="page-section__header">
        <h2 class="page-section__title">Adicionar presença</h2>
      </div>

      <div id="alunos-disponiveis-grid" class="alunos-disponiveis-grid">
        <%= render partial: "presencas/aluno_disponivel",
                   collection: @alunos_disponiveis,
                   as: :aluno,
                   locals: { aula: @aula } %>
      </div>
    </div>
  <% end %>
</div>
