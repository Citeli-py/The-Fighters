<div id="<%= dom_id aula %>" class="item-card">
  <div style="display: flex; align-items: center; justify-content: space-between; gap: 0.5rem;">
    <p class="item-card__title" style="border: none; padding: 0; margin: 0; flex: 1;">
      <%= aula.horario.turma.nome %>
    </p>
    <span class="status-badge status-badge--<%= aula.status_nome.downcase %>">
      <%= aula.status_nome %>
    </span>
  </div>

  <div class="item-card__meta">
    <div class="item-card__meta-row">
      <span class="item-card__label">Data</span>
      <%= aula.data_hora_formatada %>
    </div>
  </div>

  <div class="item-card__actions">
    <%= link_to "Ver", aula_path(aula), class: "btn btn-outline-yellow btn-sm" %>

    <% if current_user.admin? %>
      <% if aula.is_cancelada && !aula.is_realizada %>
        <%= button_to "Confirmar",
          confirm_aula_path(aula),
          method: :patch,
          class: "btn btn-primary btn-sm"
        %>
      <% end %>

      <% unless aula.is_cancelada %>
        <%= button_to "Cancelar",
          cancel_aula_path(aula),
          method: :patch,
          class: "btn btn-danger btn-sm",
          data: { turbo_confirm: "Cancelar esta aula?" }
        %>
      <% end %>
    <% end %>
  </div>
</div>
