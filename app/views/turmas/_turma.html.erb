<div id="<%= dom_id turma %>" class="item-card">
  <p class="item-card__title"><%= turma.nome %></p>

  <div class="item-card__meta">
    <div class="item-card__meta-row">
      <span class="item-card__label">Modalidade</span>
      <%= turma.modalidade.nome %>
    </div>
    <% if turma.descricao.present? %>
      <div class="item-card__meta-row">
        <span class="item-card__label">Descrição</span>
        <%= turma.descricao %>
      </div>
    <% end %>
  </div>

  <div class="item-card__actions">
    <%= link_to "Ver", turma, class: "btn btn-outline-yellow btn-sm" %>
    <% if current_user.admin_or_professor? %>
      <%= link_to "Editar", edit_turma_path(turma), class: "btn btn-ghost btn-sm" %>
      <% if local_assigns[:show].present? %>
        <%= button_to "Excluir",
          turma_path(turma),
          method: :delete,
          class: "btn btn-danger btn-sm",
          data: { turbo_confirm: "Excluir #{turma.nome}?" } %>
      <% end %>
    <% end %>
  </div>
</div>