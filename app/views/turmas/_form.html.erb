<%= form_with(model: turma) do |form| %>

  <% if turma.errors.any? %>
    <div class="form-errors">
      <h3><%= pluralize(turma.errors.count, "erro") %> encontrado(s):</h3>
      <ul>
        <% turma.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= form.label :modalidade_id, "Modalidade" %>
    <%= form.collection_select :modalidade_id,
      Modalidade.order(:nome),
      :id,
      :nome,
      { prompt: "Selecione a modalidade" },
      class: "form-input"
    %>
  </div>

  <div class="form-group">
    <%= form.label :nome, "Nome da turma" %>
    <%= form.text_field :nome, class: "form-input", placeholder: "Ex: Turma A — Iniciantes" %>
  </div>

  <div class="form-group">
    <%= form.label :descricao, "Descrição" %>
    <%= form.textarea :descricao,
      class: "form-input",
      rows: 4,
      placeholder: "Descreva a turma..."
    %>
  </div>

  <div class="form-actions">
    <%= form.submit turma.persisted? ? "Salvar alterações" : "Criar turma", class: "btn btn-primary" %>
    <%= link_to "Cancelar", turma.persisted? ? turma : turmas_path, class: "btn btn-ghost" %>
  </div>

<% end %>
