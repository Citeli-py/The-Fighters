<div class="page">
  <div class="card form-card">
    <h2 class="form-title">🥋 <%= turma.new_record? ? "Nova Turma" : "Editar Turma" %></h2>

    <%= form_with(model: turma) do |form| %>

      <% if turma.errors.any? %>
        <div class="form-errors">
          <h3><%= pluralize(turma.errors.count, "erro") %> impediram o salvamento:</h3>
          <ul>
            <% turma.errors.each do |error| %>
              <li><%= error.full_message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="form-group">
        <%= form.label :modalidade_id, "Modalidade" %>
        <%= form.collection_select :modalidade_id,
          Modalidade.order(:nome),
          :id,
          :nome,
          { prompt: "Selecione a modalidade" },
          class: "form-input"
        %>
      </div>

      <div class="form-group">
        <%= form.label :nome %>
        <%= form.text_field :nome, class: "form-input" %>
      </div>

      <div class="form-group">
        <%= form.label :descricao %>
        <%= form.textarea :descricao,
          class: "form-input",
          rows: 4
        %>
      </div>

      <div class="form-actions">
        <%= form.submit "Salvar turma", class: "btn btn-primary" %>
        <%= link_to "Cancelar", turmas_path, class: "btn btn-outline" %>
      </div>

    <% end %>
  </div>
</div>
