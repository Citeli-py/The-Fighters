<div class="page">
  <div class="page-header">
    <div>
      <%= link_to "← Dashboard", root_path, class: "back-link" %>
      <h1>Professores</h1>
    </div>
    <%= link_to "Novo professor", new_professor_path, class: "btn btn-primary" %>
  </div>

  <% if @professores.any? %>
    <div class="grid">
      <%= render @professores %>
    </div>
  <% else %>
    <p class="empty">Nenhum professor cadastrado.</p>
  <% end %>
</div>
